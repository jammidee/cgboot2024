doctype html
html
	head
		meta(charset="utf-8")
		meta(name="viewport", content="width=device-width, initial-scale=1")
		title #{app.appname} | #{title}
		include ../../layout/cgHeader.pug

		// Inline CSS for dashboard icons
		style.

			.content-wrapper {
				background-color: #ffffff;
			}

			.dashboard-icons {
				display: flex;
				flex-wrap: wrap;
				gap: 100px;
				margin-top: 40px;
				justify-content: center;
			}

			.dashboard-btn {
				display: flex;
				flex-direction: column;
				align-items: center;
				width: 100px;
				text-decoration: none;
				color: #333;
				transition: transform 0.2s, box-shadow 0.2s;
			}

			.dashboard-btn img {
				width: 120px;
				height: 120px;
				border-radius: 20%;
				margin-bottom: 8px;
				transition: transform 0.2s, box-shadow 0.2s;
				border: 1px solid #e1e1e1; /* subtle grey border */
				padding: 10px;          /* space inside the border */
				background-color: #f9f9f9; /* optional, to make border stand out */
			}

			.dashboard-btn:hover img {
				transform: translateY(-5px);
				box-shadow: 0 8px 15px rgba(0,0,0,0.25);
			}

			.dashboard-btn p {
				margin: 0;
				font-size: 14px;
				font-weight: 500;
				text-align: center;
				color: #303030; /* standard dark text color */
			}

			/* 1. Sidebar Background & Shadow Removal */
			aside.main-sidebar {
				background-color: #f8f9fa !important; /* Super light grey (Bootstrap light) */
				box-shadow: none !important;           /* Removes the elevation shadow */
				border-right: 1px solid #dee2e6;      /* Optional: subtle border instead of shadow */
			}

			/* 2. Active Link Style (The Yellow Line) */
			.nav-sidebar .nav-link.active {
				background-color: #edebeb !important; /* White background for the active item */
				color: #212529 !important;
				border-left: 4px solid #ffc107 !important;
				border-radius: 0 !important;
				padding-left: calc(1rem - 4px) !important;
				box-shadow: none !important;          /* Ensure no inner shadows */
			}

			/* 3. Active Icon Color */
			.nav-sidebar .nav-link.active i {
				color: #ffc107 !important;
			}

			/* 4. Hover State */
			.nav-sidebar .nav-link:hover {
				background-color: #e9ecef !important; /* Slightly darker grey on hover */
				color: #000 !important;
			}


	body(class="hold-transition sidebar-mini")
		.wrapper
			include ./layout/cgNavigation.pug

			// The sidebar and rightbar should be in context with the module
			include ./layout/laSideBar.pug
			include ./layout/laRightBar.pug

			//Content Wrapper. Contains page content
			div.content-wrapper
				//Content Header (Page header)
				div.content-header
					div.container-fluid
						div.row.mb-2
							div.col-sm-6
								h6.m-0 #{title}
							div.col-sm-6
								ol.breadcrumb.float-sm-right
									li.breadcrumb-item
										a( href="#" ) Home
									li.breadcrumb-item.active Dashboard


				div.content
					div.container-fluid

						.card.collapsed-card
							.card-header
								h6.card-title Minimal Graph Display
								.card-tools
									button.btn.btn-tool(type='button' data-card-widget='collapse')
										i.fas.fa-plus
							// /.card-header
							.card-body
								| This is an expanded graph of the dashboard of the module


						if (is_desktop)
							p This is a desktop!

						if (is_phone)
							p This is a phone!

						if (is_tablet)
							p This is a table!


					p
						span(style='font-size: 0.8rem;')  &nbsp; &nbsp; &nbsp;WHATEVER YOU WANT TO DO TODAY, &nbsp; BE INSPIRED! #{app.appname}
							i &nbsp;

						div.dashboard-icons

							if can('dashboard_manage', user)
								a.dashboard-btn(data-url="/dashboard")
									img(src="/resources/assets/dashboard.png", alt="Dashboard")
									p Dashboard

							a.dashboard-btn(data-urll="/calendarc")
								img(src="/resources/assets/calendarc-img.png", alt="Calendar")
								p Calendar

							a.dashboard-btn(data-urll="/attendance")
								img(src="/resources/assets/attendance.png", alt="Attendance")
								p Attendance

							a.dashboard-btn(data-urll="/flows")
								img(src="/resources/assets/flows.png", alt="Flows")
								p Flows

							a.dashboard-btn(data-urll="/employees")
								img(src="/resources/assets/employees.png", alt="Employees")
								p Employees

							a.dashboard-btn(data-urll="/hr-documents")
								img(src="/resources/assets/hr-documents.png", alt="HR Docs")
								p HR Documents

			include ../../layout/cgFooter.pug
			include ../../layout/cgJs.pug

	script.
		$(document).ready(function(){

			document.addEventListener('click', function(e) {
			const link = e.target.closest('[data-url]');
				if (link) {
					window.location.href = link.dataset.url;
				} else {
					//alert('Not yet implemented!');
				}
			});

		});