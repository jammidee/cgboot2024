doctype html
html
    head
        meta(charset="utf-8")
        meta(name="viewport", content="width=device-width, initial-scale=1")
        title #{app.appname} | Calendar
        include ../../layout/cgHeader.pug

        //- FullCalendar CSS CDN
        link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.css")

        style.
            /* Force the body and main wrapper to occupy the full screen height */
            html, body, .wrapper {
                height: 100% !important;
                margin: 0;
                padding: 0;
            }

            .content-wrapper {
                background: url('/resources/assets/img/logo/bgnd/cloud.jpg') no-repeat center center fixed !important;
                background-size: cover !important;
                height: 100% !important;
                display: flex;
                flex-direction: column;
            }

            /* Force the layout containers to stretch fully */
            .content, .container-fluid {
                padding: 0 !important;
                margin: 0 !important;
                width: 100%;
                height: 100% !important;
                display: flex;
                flex-direction: column;
                flex: 1;
            }

            /* Give the calendar container a solid background */
            #calendar-container {
                flex: 1;
                padding: 20px;
                background: rgba(255, 255, 255, 0.95); 
                box-sizing: border-box;
                overflow-y: auto; /* Adds scrolling if the squares overflow vertically */
            }

            #calendar {
                width: 100% !important;
            }

            /* --- LIGHT BLACK FONT STYLING --- */
            #calendar-container, 
            #calendar .fc {
                color: #333333 !important; 
            }

            #calendar .fc a,
            #calendar .fc-col-header-cell-cushion,
            #calendar .fc-daygrid-day-number {
                color: #444444 !important; 
                text-decoration: none;
            }

            /* --- THE SQUARE BOX FIX --- */

            /* 1. Reset standard row and table heights so they don't force stretching */
            .fc .fc-daygrid-body,
            .fc .fc-daygrid-body table,
            .fc .fc-scrollgrid-sync-table,
            .fc .fc-daygrid-day {
                height: auto !important;
                min-height: 0 !important;
            }

            /* 2. Make the day cell frame behave like a flex container */
            #calendar .fc-daygrid-day-frame {
                position: relative !important;
                height: auto !important;
                min-height: 0 !important;
                display: flex !important;
                flex-direction: column;
            }

            /* 3. The trick: Use a pseudo-element with 100% padding to force height = width */
            #calendar .fc-daygrid-day-frame::before {
                content: "";
                display: block;
                padding-top: 100%; /* Matches the exact width of the box */
            }

            /* 4. Absolute position the actual contents (dates/events) so they sit inside the square properly */
            #calendar .fc-daygrid-day-top,
            #calendar .fc-daygrid-day-events {
                position: absolute;
                left: 0;
                right: 0;
                background: transparent;
            }

            #calendar .fc-daygrid-day-top {
                top: 0;
                padding: 4px;
                z-index: 2;
            }

            #calendar .fc-daygrid-day-events {
                top: 25px; /* Pushes events below the date number */
                bottom: 0;
                overflow-y: auto; /* Scroll individual cell events if they overflow */
            }

    body( class="hold-transition layout-top-nav" )
        .wrapper

            // Content Wrapper
            div.content-wrapper
                div.content
                    div.container-fluid

                        //- Calendar mounting point
                        div#calendar-container
                            div#calendar


            include ../../layout/cgFooter-no-session.pug
            include ../../layout/cgJs.pug

    //- FullCalendar JS CDN
    script(src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.js")

    script.
        $(document).ready(function(){
            console.log("Page ready");

            var calendarEl = document.getElementById('calendar');

            var calendar = new FullCalendar.Calendar(calendarEl, {
                initialView: 'dayGridMonth',
                // 'auto' hands over layout height control directly to our CSS overrides
                height: 'auto', 
                headerToolbar: {
                    left: 'prev,next today',
                    center: 'title',
                    right: 'dayGridMonth,timeGridWeek,timeGridDay'
                },
                events: [
                    {
                        title: 'Sample Event',
                        start: new Date().toISOString().split('T')[0]
                    }
                ]
            });

            calendar.render();

            setTimeout(function() {
                calendar.updateSize();
            }, 200);
            
        });