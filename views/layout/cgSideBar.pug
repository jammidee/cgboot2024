// Main Sidebar Container
aside.main-sidebar.sidebar-light-yellow.elevation-2
	// Brand Logo
	a.brand-link(href="/dashboard")
		img.brand-image.img-circle.elevation-1(src="/resources/images/logos/logo160.png", alt="AdminLTE Logo", style="opacity: .8")
		span.brand-text.font-weight-light Lalulla

	// Sidebar
	.sidebar
		// Sidebar user panel (optional)
		//.user-panel.mt-3.pb-3.mb-3.d-flex
			.image
				img.img-circle.elevation-2(src="/resources/images/logos/logo160.png", alt="User Image")
			.info
				a.d-block Alexander Pierce

		// Sidebar Menu
		nav.mt-2
			ul.nav.nav-pills.nav-sidebar.flex-column(data-widget="treeview", role="menu")

				if can('dashboard_manage', user)
					li.nav-item
						a.nav-link(href="#", onclick="window.location='/dashboard'; return false;")
							i.nav-icon.fas.fa-th
							p Dashboard

				if can('template_manage', user)
					li.nav-item
						a.nav-link(href="#", onclick="window.location='/module/template'; return false;")
							i.nav-icon.fas.fa-th
							p Template

				// Add icons to the links using the .nav-icon class
				// with font-awesome or any other icon font library
				li.nav-item.menu-close
					a.nav-link.active(href="#")
						i.nav-icon.fas.fa-tachometer-alt
						p
							| Starter Pages
							i.right.fas.fa-angle-left
					ul.nav.nav-treeview
						li.nav-item
							a.nav-link.active(href="#")
								i.far.fa-circle.nav-icon
								p Active Page
						li.nav-item
							a.nav-link(href="#")
								i.far.fa-circle.nav-icon
								p Inactive Page
								
				//- Check if allowed to manage page. It cpntrols the sidebar
				if can('dashboard_manage', user)
					li.nav-item
						a.nav-link(href="#")
							i.nav-icon.fas.fa-th
							p
								| Simple Link
								span.right.badge.badge-danger New

				li.nav-item
					a.nav-link.logout-btn(href="#" data-href="/auth/logout")
						i.nav-icon.fas.fa-sign-out-alt
						p Logout
